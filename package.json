{
  "name": "divezone.company",
  "version": "1.0.0",
  "description": "DiveZone.Company website",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "watch:sass": "sass --watch sass:assets/css",
    "watch:hugo": "hugo server -D --disableFastRender --navigateToChanged",
    "build:sass": "sass --no-source-map sass:assets/css",
    "build:hugo": "hugo --minify",
    "start": "npm-run-all build:sass --parallel watch:*",
    "build": "npm-run-all build:sass build:hugo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiveZoneCompany/divezone.company"
  },
  "author": "The DiveZone Company",
  "bugs": {
    "url": "https://github.com/DiveZoneCompany/divezone.company/issues"
  },
  "homepage": "https://divezone.company/",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "postcss-hash": "^3.0.0",
    "postcss-load-config": "^6.0.1",
    "postcss-merge-rules": "^8.0.0",
    "postcss-scss": "^4.0.9",
    "sass": "^1.99.0"
  }
}
